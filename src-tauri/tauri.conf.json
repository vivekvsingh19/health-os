{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HealthOS Posture Monitor",
  "version": "1.0.0",
  "identifier": "com.vivek.healthos",

  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HealthOS Posture Monitor",
        "width": 800,
        "height": 600,
        "minWidth": 480,
        "minHeight": 360,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false,
        "transparent": false,
        "skipTaskbar": false,
        "visible": true,
        "shadow": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' http://127.0.0.1:5000 data: blob:; connect-src 'self' http://127.0.0.1:5000; media-src 'self' http://127.0.0.1:5000"
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/healthos-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}